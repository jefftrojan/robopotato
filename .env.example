# Required: secret key for HMAC token signing (use a long random string in production)
ROBOPOTATO_SECRET=change-me-use-a-long-random-string

# Optional: server address (default: 127.0.0.1:7878)
ROBOPOTATO_HOST=127.0.0.1
ROBOPOTATO_PORT=7878

# Optional: token TTL in seconds (default: 3600 = 1 hour)
ROBOPOTATO_TOKEN_TTL=3600

# Optional: enable SQLite persistence (default: false)
ROBOPOTATO_PERSIST=false
ROBOPOTATO_DB_PATH=robopotato.db
