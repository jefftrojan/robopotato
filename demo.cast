[0.000, "o", "\r\n\u001b[1m  Summary\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  \u001b[0;32mвњ“\u001b[0m  Namespace isolation    workers cannot touch global.* or other agents' namespaces\r\n"]
[0.000, "o", "  \u001b[0;32mвњ“\u001b[0m  Role enforcement       observers are permanently read-only\r\n"]
[0.001, "o", "  \u001b[0;32mвњ“\u001b[0m  OCC conflict detection concurrent stale writes produce 409, not silent overwrites\r\n"]
[0.000, "o", "  \u001b[0;32mвњ“\u001b[0m  Mid-task revocation    revoked tokens rejected immediately, no restart needed\r\n"]
[0.000, "o", "  \u001b[0;32mвњ“\u001b[0m  Token forgery rejected wrong HMAC secret в†’ 401 every time\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  All of the above enforced at the infrastructure layer.\r\n"]
[0.000, "o", "  \u001b[2mNo prompt-engineering required.\u001b[0m\r\n\r\n"]
